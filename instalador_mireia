    def _save_config(self):
        modelo = self._cfg["modelo"].get().strip()
        if not modelo:
            messagebox.showwarning("Campo vacío","Especifica un modelo de Ollama.")
            return
        cfg = {
            "modelo":         modelo,
            "whisper":        self._cfg["whisper"].get().strip(),
            "wake_variantes": self._cfg["wake_variantes"].get().strip(),
            "sistema":        self._sys_text.get("1.0","end").strip(),
            "piper_bin":      self._cfg["piper_bin"].get().strip(),
            "voice_model":    self._cfg["voice_model"].get().strip(),
            "temperatura":    self._cfg["temperatura"].get().strip(),
            "num_predict":    self._cfg["num_predict"].get().strip(),
        }
        save_config(cfg)
        self.log(f"  ✓  Config guardada → {CONFIG_PATH}","ok")
        self._footer(f"Guardado: {CONFIG_PATH}")
        self._update_status_row("config","ok",str(CONFIG_PATH))
        self._update_run_cfg_label()
        messagebox.showinfo("Guardado", f"Configuración guardada en:\n{CONFIG_PATH}")

    def _reload_config(self):
        cfg = load_config()
        if not cfg: return
        for k in ("modelo","whisper","wake_variantes","piper_bin","voice_model",
                  "temperatura","num_predict"):
            if k in self._cfg and k in cfg:
                self._cfg[k].set(cfg[k])
        self._sys_text.delete("1.0","end")
        self._sys_text.insert("1.0", cfg.get("sistema",""))
        self._update_run_cfg_label()

