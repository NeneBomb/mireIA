def run_assistant(debug=False):
    """Lanza el asistente de voz en la terminal."""
    if not CONFIG_PATH.exists():
        sys.exit(f"✗  No se encuentra {CONFIG_PATH}\n   Ejecuta primero: python3 mireia.py")

    with open(CONFIG_PATH) as f:
        cfg = json.load(f)

    if not debug:
        devnull = os.open(os.devnull, os.O_WRONLY)
        os.dup2(devnull, sys.stderr.fileno())
        warnings.filterwarnings("ignore")

    # Importaciones pesadas: requieren el venv activo o instaladas en sistema
    try:
        import ollama as _ollama
        import whisper as _whisper
        import speech_recognition as _sr
    except ImportError as e:
        sys.exit(f"✗  Librería no encontrada: {e}\n"
                 f"   Activa el venv:  source {VENV_DIR}/bin/activate\n"
                 f"   O reinstala:     python3 mireia.py")

    piper_bin   = cfg.get("piper_bin",   str(PIPER_BIN))
    voice_model = cfg.get("voice_model", str(voice_model_path()))

    # ── TTS ────────────────────────────────────────────────────────────────────
    class TTS:
        def __init__(self):
            self.q = queue.Queue()
            threading.Thread(target=self._loop, daemon=True).start()

        def say(self, txt):
            t = re.sub(r'[*_#`]', '', txt).strip()
            if t: self.q.put(t)

        def wait(self):
            self.q.join()

        def _loop(self):
            while True:
                t = self.q.get()
                if os.path.exists(piper_bin) and os.path.exists(voice_model):
                    try:
                        t_safe = t.replace('"','').replace("'","")
                        cmd = (f'echo "{t_safe}" | {piper_bin} --model {voice_model} '
                               f'--output_raw | aplay -r 22050 -f S16_LE -t raw -D default')
                        subprocess.run(cmd, shell=True,
                                       stdout=subprocess.DEVNULL,
                                       stderr=subprocess.DEVNULL)
                    except Exception:
                        self._fallback(t)
                else:
                    self._fallback(t)
                self.q.task_done()

        def _fallback(self, t):
            subprocess.run(["espeak-ng","-v","es-es+f2","-s","150", t],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    # ── Escucha ────────────────────────────────────────────────────────────────
    class Listener:
        def __init__(self):
            self.r = _sr.Recognizer()
            self.r.pause_threshold      = 0.8
            self.r.dynamic_energy_threshold = True

        def listen(self):
            with _sr.Microphone() as s:
                self.r.adjust_for_ambient_noise(s, duration=0.5)
                try:
                    audio = self.r.listen(s, timeout=10, phrase_time_limit=15)
                    with open(_TMP_WAV, "wb") as f:
                        f.write(audio.get_wav_data())
                    return True
                except Exception:
                    return False

    print(f"─── {APP_NAME} {VERSION} ───  Cargando modelos…")
    model_stt = _whisper.load_model(cfg["whisper"], device="cpu")
    tts       = TTS()
    listener  = Listener()
    history   = []
    wakes     = [v.strip().lower() for v in cfg["wake_variantes"].split(",")]

    print(f"✨  Activa. Di '{wakes[0]}' para hablar.  Ctrl+C para salir.\n")

    while True:
        try:
            print("💤  En espera…", end="\r")
            if not listener.listen():
                continue

            res      = model_stt.transcribe(str(_TMP_WAV), language="es", fp16=False)
            user_txt = res["text"].strip()

            if len(user_txt) < 3 or not any(w in user_txt.lower() for w in wakes):
                continue

            print(f"\n🗣  Tú: {user_txt}")

            peticion = user_txt
            for w in wakes:
                peticion = re.sub(re.escape(w), "", peticion, flags=re.IGNORECASE)
            peticion = peticion.strip(",?¿!¡ ")

            if not peticion:
                tts.say("¿Dime?"); tts.wait(); continue

            print("🤖  IA: ", end="", flush=True)

            messages = [{"role":"system","content":cfg["sistema"]}]
            messages += history
            messages.append({"role":"user","content":peticion})

            stream = _ollama.chat(
                model=cfg["modelo"], messages=messages, stream=True,
                options={"temperature":0.4,"top_p":0.9,
                         "num_ctx":4096,"num_predict":800})

            full, buf = "", ""
            for chunk in stream:
                token = chunk['message']['content']
                print(token, end="", flush=True)
                full += token; buf += token
                if any(c in token for c in ".!?\n"):
                    tts.say(buf); buf = ""
            if buf: tts.say(buf)
            print()

            history.append({"role":"user",      "content":peticion})
            history.append({"role":"assistant", "content":full})
            history = history[-6:]
            tts.wait()

        except KeyboardInterrupt:
            print(f"\n👋  Apagando {APP_NAME}…")
            break
        except Exception as e:
            if debug: print(f"\n⚠  Error: {e}")
            time.sleep(1)


