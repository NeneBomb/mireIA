    def _update_run_cfg_label(self):
        cfg = load_config()
        if cfg:
            texto = (f"Modelo: {cfg.get('modelo','?')}  ·  "
                     f"Whisper: {cfg.get('whisper','?')}  ·  "
                     f"Wake: {cfg.get('wake_variantes','?')}")
        else:
            texto = "Sin configuración — ve a CONFIGURAR primero"
        self.after(0, lambda: self._run_cfg_lbl.configure(text=texto))

    def _start_assistant_process(self):
        if not CONFIG_PATH.exists():
            messagebox.showwarning("Sin configuración",
                "Crea primero una configuración en la pestaña CONFIGURAR.")
            self.nb.select(1); return

        if not VENV_PY.exists():
            messagebox.showwarning("Sin entorno virtual",
                "Instala el entorno primero desde la pestaña INSTALAR.")
            self.nb.select(0); return

        self._run_log_append("── Iniciando MireIA …", "sys")
        self._set_run_state(True)

        script = str(Path(__file__).resolve())
        cmd    = [str(VENV_PY), script, "--run"]
        try:
            self._assistant_proc = subprocess.Popen(
                cmd,
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, bufsize=1,
            )
            threading.Thread(target=self._read_proc_output, daemon=True).start()
        except Exception as e:
            self._run_log_append(f"✗ Error: {e}", "sys")
            self._set_run_state(False)

    def _read_proc_output(self):
        proc = self._assistant_proc
        if not proc: return
        for line in proc.stdout:
            line = line.rstrip()
            if not line: continue
            if "Tú:" in line:
                self._run_log_append(line, "usr")
            elif "IA:" in line:
                self._run_log_append(line, "ia")
            else:
                self._run_log_append(line, "sys")
        proc.wait()
        self.after(0, lambda: self._set_run_state(False))
        self.after(0, lambda: self._run_log_append("── Proceso terminado.", "sys"))

    def _stop_assistant(self):
        if self._assistant_proc:
            self._assistant_proc.terminate()
            self._assistant_proc = None
        self._set_run_state(False)

    def _set_run_state(self, running):
        if running:
            self._run_active = True
            self._run_status_lbl.configure(text="Asistente activo", fg=C["success"])
            self._run_anim_lbl.configure(fg=C["success"])
            self._btn_start.configure(state="disabled")
            self._btn_stop.configure(state="normal")
            self._animate_run()
        else:
            self._run_active = False
            self._run_status_lbl.configure(text="Asistente en reposo", fg=C["muted"])
            self._run_anim_lbl.configure(text="◌", fg=C["muted"])
            self._btn_start.configure(state="normal")
            self._btn_stop.configure(state="disabled")

    def _animate_run(self):
        if not self._run_active: return
        c = self._run_anim_chars
        self._run_anim_idx = (self._run_anim_idx + 1) % len(c)
        self._run_anim_lbl.configure(text=c[self._run_anim_idx])
        self.after(220, self._animate_run)

    def _run_log_append(self, msg, tag="sys"):
        def _do():
            self._run_log.configure(state="normal")
            self._run_log.insert("end", msg+"\n", tag)
            self._run_log.see("end")
            self._run_log.configure(state="disabled")
        self.after(0, _do)

    # ── Estado ─────────────────────────────────────────────────────────────────

    def _run_status_check(self):
        """Check silencioso para la pestaña Estado (no escribe en el log)."""
        if self._check_running:
            return
        threading.Thread(target=self._silent_status_thread, daemon=True).start()

    def _silent_status_thread(self):
        """Actualiza solo los iconos de la pestaña Estado sin tocar el log."""
        v = sys.version_info
        self._update_status_row("python",
            "ok" if v >= (3,8) else "err", f"{v.major}.{v.minor}.{v.micro}")
        self._update_status_row("venv",
            "ok" if VENV_PY.exists() else "warn",
            "" if VENV_PY.exists() else "no creado")
        for pkg, key, imp in [
            ("whisper","whisper","whisper"),
            ("SpeechRecognition","sr","speech_recognition"),
            ("pyaudio","pyaudio","pyaudio"),
            ("ollama","ollama_lib","ollama"),
        ]:
            ok = venv_has(imp)
            self._update_status_row(key, "ok" if ok else "warn",
                                    "" if ok else "no instalado")
        self._update_status_row("piper_bin",
            "ok" if PIPER_BIN.exists() else "warn",
            str(PIPER_BIN) if PIPER_BIN.exists() else "no instalado")
        vm = voice_model_path()
        self._update_status_row("voice_mdl",
            "ok" if vm.exists() else "warn",
            vm.name if vm.exists() else "no descargado")
        if shutil.which("ollama"):
            rc, _ = run_cmd(["ollama","list"], timeout=4)
            self._update_status_row("ollama_srv",
                "ok" if rc == 0 else "warn",
                "" if rc == 0 else "servicio offline")
        else:
            self._update_status_row("ollama_srv", "warn", "no instalado")
        self._update_status_row("config",
            "ok" if CONFIG_PATH.exists() else "warn",
            str(CONFIG_PATH) if CONFIG_PATH.exists() else "no creado")
        for tool, key in [("espeak-ng","espeak"),("aplay","aplay"),("ffmpeg","ffmpeg")]:
            self._update_status_row(key,
                "ok" if shutil.which(tool) else "warn",
                "" if shutil.which(tool) else "no instalado")
        self._update_status_row("audio_grp",
            "ok" if in_audio_group() else "warn",
            "OK" if in_audio_group() else "sudo usermod -aG audio $USER")
        free = disk_free_mb()
        self._update_status_row("disk",
            "ok" if free >= 2000 else "warn", f"{free} MB libres")


