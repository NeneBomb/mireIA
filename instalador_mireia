def run_cmd(cmd, shell=False, timeout=None):
    """(returncode, stdout+stderr)"""
    try:
        r = subprocess.run(cmd, shell=shell, capture_output=True,
                           text=True, timeout=timeout)
        return r.returncode, (r.stdout or "") + (r.stderr or "")
    except subprocess.TimeoutExpired:
        return -1, "Timeout"
    except Exception as e:
        return -1, str(e)


def is_root():
    return os.geteuid() == 0


def sudo(cmd_list):
    return (["sudo"] + cmd_list) if not is_root() else cmd_list


def detect_pm():
    for pm in ("apt-get","dnf","pacman","zypper"):
        if shutil.which(pm):
            return pm
    return None


def disk_free_mb(path="/"):
    st = os.statvfs(path)
    return st.f_bavail * st.f_frsize // (1024 * 1024)


def in_audio_group():
    try:
        import grp
        groups = [g.gr_name for g in grp.getgrall() if os.getlogin() in g.gr_mem]
        return "audio" in groups
    except Exception:
        return True   # no bloquear si no podemos comprobarlo


def load_config():
    if CONFIG_PATH.exists():
        try:
            with open(CONFIG_PATH) as f:
                return json.load(f)
        except Exception:
            return {}
    return {}


def save_config(cfg):
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)


def voice_model_path():
    """Devuelve la ruta efectiva del modelo de voz (preferir nombre canónico)."""
    canonical = MODELS_DIR / _VOICE_CANONICAL_NAME
    if canonical.exists():
        return canonical
    # fallback: nombre original descargado
    original = MODELS_DIR / "es_ES-mls_10246-medium.onnx"
    if original.exists():
        return original
    return canonical   # aunque no exista


def venv_has(import_name):
    if VENV_PY.exists():
        rc, _ = run_cmd([str(VENV_PY), "-c", f"import {import_name}"])
        return rc == 0
    rc, _ = run_cmd([sys.executable, "-c", f"import {import_name}"])
    return rc == 0


