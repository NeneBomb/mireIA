    def _set_step(self, key, state):
        MAP = {
            "pending": ("○", C["muted"]),
            "running": ("◌", C["warning"]),
            "ok":      ("✓", C["success"]),
            "warn":    ("⚠", C["warning"]),
            "skip":    ("–", C["muted"]),
            "err":     ("✗", C["error"]),
        }
        icon, color = MAP.get(state, ("?", C["muted"]))
        lbl = self._step_icons.get(key)
        if lbl:
            self.after(0, lambda: lbl.configure(text=icon, fg=color))

    def _update_badge(self, text, fg):
        self.after(0, lambda: self._badge_lbl.configure(text=text, fg=fg))

    def _update_status_row(self, key, state, note=""):
        MAP = {"ok":("✓",C["success"]),"warn":("⚠",C["warning"]),
               "err":("✗",C["error"]),"skip":("–",C["muted"])}
        icon, color = MAP.get(state, ("…",C["muted"]))
        def _do():
            row = self._status_rows.get(key)
            if row:
                row[0].configure(text=icon, fg=color)
                if note: row[1].configure(text=note)
        self.after(0, _do)

    def _footer(self, msg):
        self.after(0, lambda: self._footer_lbl.configure(text=msg))

    # ── Logging ───────────────────────────────────────────────────────────────

    def log(self, msg, tag="info"):
        self._log_q.put((msg, tag))

    def set_progress(self, val, label=""):
        self._prog_q.put((val, label))

    def _clear_log(self):
        self._log_widget.configure(state="normal")
        self._log_widget.delete("1.0","end")
        self._log_widget.configure(state="disabled")

    def _poll_queues(self):
        try:
            while True:
                msg, tag = self._log_q.get_nowait()
                self._log_widget.configure(state="normal")
                self._log_widget.insert("end", msg+"\n", tag)
                self._log_widget.see("end")
                self._log_widget.configure(state="disabled")
        except queue.Empty:
            pass
        try:
            while True:
                val, lbl = self._prog_q.get_nowait()
                self._progress["value"] = val
                self._prog_lbl.configure(text=lbl)
        except queue.Empty:
            pass
        self.after(80, self._poll_queues)

