def check_tk():
    try:
        r = tk.Tk(); r.destroy(); return True
    except Exception:
        return False


def main():
    parser = argparse.ArgumentParser(
        description=f"{APP_NAME} {VERSION} — Asistente de voz local")
    parser.add_argument("--run",   action="store_true",
                        help="Arrancar el asistente de voz directamente (sin GUI)")
    parser.add_argument("--debug", action="store_true",
                        help="Modo debug (muestra errores de audio)")
    args = parser.parse_args()

    if platform.system() != "Linux":
        print(f"⚠  {APP_NAME} está diseñado para Linux.")
        sys.exit(1)

    if args.run or args.debug:
        run_assistant(debug=args.debug)
        return

    if not check_tk():
        print("✗  tkinter no disponible.")
        print("   Instala: sudo apt install python3-tk")
        sys.exit(1)

    app = MireIAApp()
    app.mainloop()


if __name__ == "__main__":
    main()
