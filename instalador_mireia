    def _initial_check(self):
        if self._check_running:
            return
        self._update_badge("verificando...", C["muted"])
        threading.Thread(target=self._check_thread, daemon=True).start()

    def _check_thread(self):
        self._check_running = True
        issues = []
        self.log("─────────────────────────────────────────────", "sub")
        self.log("  COMPROBACIÓN DEL SISTEMA", "head")
        self.log("─────────────────────────────────────────────", "sub")

        v = sys.version_info
        if v >= (3,8):
            self.log(f"  python {v.major}.{v.minor}.{v.micro}  OK", "ok")
            self._update_status_row("python","ok",f"{v.major}.{v.minor}.{v.micro}")
        else:
            self.log(f"  python {v.major}.{v.minor} demasiado antiguo","err")
            self._update_status_row("python","err","< 3.8")
            issues.append("Python")

        if VENV_PY.exists():
            self.log(f"  venv  OK", "ok")
            self._update_status_row("venv","ok"); self._set_step("venv","ok")
        else:
            self.log(f"  venv  no encontrado","warn")
            self._update_status_row("venv","warn","no creado"); self._set_step("venv","pending")
            issues.append("venv")

        for pkg, key, imp in [
            ("whisper","whisper","whisper"),
            ("SpeechRecognition","sr","speech_recognition"),
            ("pyaudio","pyaudio","pyaudio"),
            ("ollama","ollama_lib","ollama"),
        ]:
            ok = venv_has(imp)
            self.log(f"  {pkg}  {'OK' if ok else 'falta'}", "ok" if ok else "warn")
            self._update_status_row(key, "ok" if ok else "warn",
                                    "" if ok else "no instalado")
            if not ok: issues.append(pkg)
        pip_ok = not any(p in issues for p in ["whisper","SpeechRecognition","pyaudio","ollama"])
        self._set_step("pip","ok" if pip_ok else "pending")

        if PIPER_BIN.exists():
            self.log(f"  piper  OK","ok")
            self._update_status_row("piper_bin","ok",str(PIPER_BIN)); self._set_step("piper","ok")
        else:
            self.log(f"  piper  no encontrado","warn")
            self._update_status_row("piper_bin","warn","no instalado"); self._set_step("piper","pending")
            issues.append("piper")

        vm = voice_model_path()
        if vm.exists():
            self.log(f"  modelo voz  OK","ok")
            self._update_status_row("voice_mdl","ok",vm.name); self._set_step("voice","ok")
        else:
            self.log(f"  modelo voz  no encontrado","warn")
            self._update_status_row("voice_mdl","warn","no descargado"); self._set_step("voice","pending")
            issues.append("voz")

        if shutil.which("ollama"):
            rc, out = run_cmd(["ollama","list"], timeout=5)
            if rc == 0:
                self.log(f"  ollama  OK","ok")
                self._update_status_row("ollama_srv","ok"); self._set_step("ollama","ok")
                cfg = load_config()
                modelo = cfg.get("modelo","")
                if modelo and not any(modelo.split(":")[0] in l for l in out.splitlines()):
                    self.log(f"  ⚠  modelo '{modelo}' no descargado","warn")
                    self._set_step("ollama","warn")
            else:
                self.log(f"  ollama  servicio inactivo","warn")
                self._update_status_row("ollama_srv","warn","servicio offline")
                self._set_step("ollama","warn")
        else:
            self.log(f"  ollama  no instalado","warn")
            self._update_status_row("ollama_srv","warn","no instalado"); self._set_step("ollama","warn")
            issues.append("ollama")

        if CONFIG_PATH.exists():
            self.log(f"  config  OK","ok")
            self._update_status_row("config","ok",str(CONFIG_PATH))
        else:
            self.log(f"  config  no existe","warn")
            self._update_status_row("config","warn","no creado")
            issues.append("config")
            if not self._wizard_open:
                self.after(500, self._open_config_wizard)

        for tool, key in [("espeak-ng","espeak"),("aplay","aplay"),("ffmpeg","ffmpeg")]:
            ex = bool(shutil.which(tool))
            self._update_status_row(key, "ok" if ex else "warn",
                                    "" if ex else "no instalado")

        audio_ok = in_audio_group()
        self._update_status_row("audio_grp", "ok" if audio_ok else "warn",
                                "OK" if audio_ok else "puede necesitar: sudo usermod -aG audio $USER")

        free = disk_free_mb()
        disk_ok = free >= 2000
        self._update_status_row("disk", "ok" if disk_ok else "warn",
                                f"{free} MB libres")

        self._set_step("sys_deps","pending" if issues else "ok")
        self._set_step("preflight","ok" if disk_ok else "warn")

        if issues:
            self.log(f"\n  ⚠  Pendiente: {', '.join(issues)}", "warn")
            self._update_badge("pendiente", C["warning"])
        else:
            self.log("\n  ✓  Sistema listo.", "ok")
            self._update_badge("listo", C["success"])

        self._update_run_cfg_label()
        self._check_running = False

