    def _start_install(self):
        if self._install_running:
            return
        self._install_running = True
        self._btn_install.configure(state="disabled")
        threading.Thread(target=self._install_thread, daemon=True).start()

    def _install_thread(self):
        N = 8
        step = 0
        def adv(key, title):
            nonlocal step
            step += 1
            self._set_step(key, "running")
            self.log(f"\n── [{step}/{N}] {title} ──", "head")
            self.set_progress(int(step/N*100), f"[{step}/{N}] {title}")

        # 0. Pre-vuelo
        adv("preflight","Pre-vuelo")
        warnings_list = []
        arch = platform.machine()
        self.log(f"  Arquitectura: {arch}", "info")
        if arch not in _ARCH_MAP:
            self.log(f"  ⚠  Arquitectura no soportada en Piper precompilado","warn")
            warnings_list.append("arch")
        free = disk_free_mb()
        self.log(f"  Disco libre: {free} MB", "info")
        if free < _DISK_NEEDED_MB:
            self.log(f"  ⚠  Se recomiendan {_DISK_NEEDED_MB} MB, hay {free} MB","warn")
            warnings_list.append("disco")
        if not in_audio_group():
            self.log(f"  ⚠  El usuario no está en el grupo 'audio'","warn")
            self.log(f"     Solución: sudo usermod -aG audio $USER  (requiere re-login)","warn")
        self._set_step("preflight","warn" if warnings_list else "ok")

        # 1. Dependencias del sistema
        adv("sys_deps","Dependencias del sistema")
        ok = self._install_sys_deps()
        self._set_step("sys_deps","ok" if ok else "warn")

        # 2. Entorno virtual
        adv("venv","Entorno virtual Python")
        ok = self._create_venv()
        self._set_step("venv","ok" if ok else "err")
        if not ok:
            self.log("Abortando instalación.","err")
            self._finalize(False); return

        # 3. pip
        adv("pip","Paquetes Python")
        ok = self._install_pip()
        self._set_step("pip","ok" if ok else "warn")

        # 4. Piper
        adv("piper","Piper TTS")
        ok = self._install_piper()
        self._set_step("piper","ok" if ok else "warn")

        # 5. Modelo de voz
        adv("voice","Modelo de voz")
        ok = self._install_voice()
        self._set_step("voice","ok" if ok else "warn")

        # 6. Modelo Ollama
        adv("ollama","Modelo de IA (ollama pull)")
        self._pull_ollama_model()
        self._set_step("ollama","ok")

        # 7. Lanzadores
        adv("launcher","Creando lanzadores")
        self._create_launchers()
        self._set_step("launcher","ok")

        self.set_progress(100,"Completado")
        self._finalize(True)

    def _finalize(self, ok):
        def _do():
            self._install_running = False
            self._btn_install.configure(state="normal")
            if ok:
                self.log("\nInstalación completada.","ok")
                self._update_badge("listo", C["success"])
                if not CONFIG_PATH.exists():
                    self.after(400, self._open_config_wizard)
                else:
                    self.after(400, lambda: self.nb.select(1))
            else:
                self.log("\n✗  Instalación incompleta.","err")
                self._update_badge("error", C["error"])
        self.after(0, _do)

    # ── Pasos individuales ────────────────────────────────────────────────────

    def _install_sys_deps(self):
        pm = detect_pm()
        if not pm:
            self.log("  ⚠  Gestor de paquetes no detectado. Omitiendo.","warn")
            return False
        self.log(f"  Gestor: {pm}","info")
        if pm in ("apt-get","apt"):
            cmds = [
                sudo([pm,"update","-qq"]),
                sudo([pm,"install","-y"]+_APT_PKGS),
            ]
        elif pm == "dnf":
            cmds = [sudo([pm,"install","-y"]+_DNF_PKGS)]
        elif pm == "pacman":
            cmds = [sudo([pm,"-Sy","--noconfirm"]+_PAC_PKGS)]
        else:
            cmds = []
        for c in cmds:
            self.log(f"  $ {' '.join(c)}","sub")
            rc, out = run_cmd(c)
            for l in out.splitlines()[-5:]:
                if l.strip(): self.log(f"    {l}","info")
            if rc not in (0, 100):   # 100 = apt nada que hacer
                self.log(f"  ⚠  código {rc} (¿requiere contraseña sudo?)","warn")
        self.log("  ✓  Dependencias procesadas.","ok")
        return True

    def _create_venv(self):
        if VENV_PY.exists():
            self.log(f"  Venv ya existe. Omitiendo.","ok")
            return True
        self.log(f"  Creando {VENV_DIR} …","info")
        rc, out = run_cmd([sys.executable,"-m","venv",str(VENV_DIR)])
        if rc != 0:
            self.log(f"  ✗  {out}","err"); return False
        self.log("  ✓  Venv creado.","ok")
        return True

    def _install_pip(self):
        if not VENV_PIP.exists():
            self.log("  ✗  pip del venv no encontrado.","err"); return False
        all_ok = True
        for pkg in _PIP_PKGS:
            self.log(f"  pip install {pkg} …","info")
            rc, out = run_cmd([str(VENV_PIP),"install","--upgrade",pkg],timeout=300)
            for l in out.splitlines()[-3:]:
                if l.strip(): self.log(f"    {l}","sub")
            if rc == 0:
                self.log(f"  ✓  {pkg}","ok")
            else:
                self.log(f"  ✗  {pkg}","err"); all_ok = False
        return all_ok

    def _install_piper(self):
        if PIPER_BIN.exists():
            self.log("  Piper ya instalado. Omitiendo.","ok"); return True
        arch   = platform.machine()
        tgz_fn = _ARCH_MAP.get(arch,"piper_linux_x86_64.tar.gz")
        url    = _PIPER_BASE + tgz_fn
        tmp    = Path(tempfile.gettempdir()) / "piper.tar.gz"
        self.log(f"  Descargando {tgz_fn} …","info")
        rc, out = run_cmd(["wget","-q","-O",str(tmp),url], timeout=180)
        if rc != 0:
            rc, out = run_cmd(["curl","-L","-o",str(tmp),url], timeout=180)
        if rc != 0:
            self.log(f"  ✗  Descarga fallida. URL manual:\n     {url}","err")
            return False
        PIPER_DIR.mkdir(parents=True, exist_ok=True)
        rc, out = run_cmd(["tar","-xzf",str(tmp),"-C",str(PIPER_DIR),"--strip-components=1"])
        if rc != 0:
            self.log(f"  ✗  Error extrayendo: {out}","err"); return False
        if PIPER_BIN.exists():
            os.chmod(PIPER_BIN,0o755)
            self.log(f"  ✓  Piper en {PIPER_BIN}","ok"); return True
        self.log("  ✗  Binario no encontrado tras extracción.","err"); return False

    def _install_voice(self):
        canonical = MODELS_DIR / _VOICE_CANONICAL_NAME
        if canonical.exists():
            self.log(f"  Modelo de voz ya existe ({canonical.name}). Omitiendo.","ok")
            return True
        MODELS_DIR.mkdir(parents=True, exist_ok=True)
        self.log("  Descargando modelo español (~60 MB) …","info")
        tmp_onnx = MODELS_DIR / "es_ES-mls_10246-medium.onnx"
        tmp_json = MODELS_DIR / "es_ES-mls_10246-medium.onnx.json"
        ok = True
        for url, dest in [(_VOICE_ONNX, tmp_onnx), (_VOICE_JSON, tmp_json)]:
            self.log(f"  → {dest.name}","info")
            rc, out = run_cmd(["wget","-q","-O",str(dest),url], timeout=300)
            if rc != 0:
                rc, out = run_cmd(["curl","-L","-o",str(dest),url], timeout=300)
            if rc != 0:
                self.log(f"  ✗  Error descargando {dest.name}","err"); ok = False
        if ok and tmp_onnx.exists():
            # Renombrar al nombre canónico esperado por el asistente
            tmp_onnx.rename(canonical)
            # Renombrar también el json
            new_json = MODELS_DIR / (_VOICE_CANONICAL_NAME + ".json")
            if tmp_json.exists():
                tmp_json.rename(new_json)
            self.log(f"  ✓  Modelo guardado como '{_VOICE_CANONICAL_NAME}'","ok")
            # Actualizar config si existe
            cfg = load_config()
            if cfg:
                cfg["voice_model"] = str(canonical)
                save_config(cfg)
                self.log(f"  ✓  Ruta voice_model actualizada en config","ok")
            # Actualizar campo en GUI
            if "voice_model" in self._cfg:
                self.after(0, lambda: self._cfg["voice_model"].set(str(canonical)))
        return ok

    def _pull_ollama_model(self):
        if not shutil.which("ollama"):
            self.log("  ✗  Ollama no instalado. Instala desde https://ollama.com","err")
            self.log("     curl -fsSL https://ollama.com/install.sh | sh","info")
            return
        cfg   = load_config()
        model = cfg.get("modelo") or self._cfg.get("modelo","").get() if hasattr(self._cfg.get("modelo",""),"get") else "llama3.2:3b"
        if not model:
            model = "llama3.2:3b"
        # Comprobar si ya existe
        rc, out = run_cmd(["ollama","list"], timeout=10)
        base = model.split(":")[0]
        if rc == 0 and base in out:
            self.log(f"  Modelo '{model}' ya descargado. Omitiendo.","ok")
            return
        self.log(f"  ollama pull {model} (puede tardar bastante) …","warn")
        rc, out = run_cmd(["ollama","pull",model], timeout=600)
        if rc == 0:
            self.log(f"  ✓  Modelo '{model}' disponible.","ok")
        else:
            self.log(f"  ✗  Error descargando modelo. Inténtalo manualmente:","err")
            self.log(f"     ollama pull {model}","info")

